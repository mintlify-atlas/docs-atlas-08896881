  "keyFeatures": [
    "Pure-Rust implementation of the Wayland wire protocol (no libwayland required)",
    "Optional system backend using libwayland-client/server via FFI",
    "Type-safe, generated Rust bindings from Wayland XML protocol specs",
    "High-level client API: Connection, EventQueue, Dispatch trait",
    "High-level server API: Display, GlobalDispatch, Resource trait",
    "Pre-generated bindings for all official Wayland protocol extensions (xdg, wp, ext)",
    "Bindings for wlroots, KDE Plasma, and experimental protocol extensions",
    "OpenGL/EGL integration via wayland-egl",
    "Cursor theme loading via wayland-cursor",
    "Procedural macro code generator (wayland-scanner) for custom protocols",
    "Dynamic loading (dlopen) support for graceful fallback when libwayland is absent"
  ],
  "publicApiSurface": [
    "wayland_client::Connection",
    "wayland_client::EventQueue",
    "wayland_client::Dispatch",
    "wayland_client::QueueHandle",
    "wayland_client::globals::GlobalList",
    "wayland_client::protocol (auto-generated core protocol types)",
    "wayland_server::Display",
    "wayland_server::DisplayHandle",
    "wayland_server::Resource (trait)",
    "wayland_server::GlobalDispatch (trait)",
    "wayland_server::Client",
